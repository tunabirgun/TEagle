# ── TEagle .gitignore ───────────────────────────────────────────────
# Agent / editor workspace
.claude/
**/scratchpad/
*.session.json
.vs/
*.user
*.suo

# Internal-only working directories (design docs, reports, reviews, scratch validation) —
# not part of what an end user or the build needs; never published.
outdated/
manuscript/
Deliverables/
report/
review-records/
verification/
scratch_e2e/

# Build / packaging artifacts (regenerable; the shippable installer is attached to a Release)
dist/
dist_native/
build/
build_native/
*.pyi_manifest

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/

# Node / legacy web tooling
node_modules/
.cache/

# Runtime state + logs + temp
.teagle/
*.log
*.tmp

# Unused sample sequences (the app generates its demo element in code)
app/samples/

# Scientific databases & large binaries (user-installed at runtime, never committed)
databases/
models/
*.h5
*.2bit
*.nhr
*.nin
*.nsq
*.sam
# loose sequence scratch at the repo root (fixtures under tests/ are re-included below)
/*.fa
/*.fasta
/*.fna
/*.gz

# OS cruft
Thumbs.db
Desktop.ini
.DS_Store

# ── Keep (re-include) the assets the tool and its tests DO need ──────
!tests/fixtures/
!tests/fixtures/*.fasta
!app/backend/data/
!app/backend/data/*.hmm
